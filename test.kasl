import std

// Type aliases
typealias Sample = [Float; 2]

// Custom operators
operator infix ** {
    precedence: 110,
    associativity: right
}

operator prefix ~ {
    precedence: 110
}

func infix **(lhs: Float, rhs: Float) -> Float {
    return std.float.pow(lhs, rhs)
}

// Struct definitions
struct Oscillator {
    var frequency = 440.0
    var phase = 0.0
    var amplitude = 1.0
    var active = false
}

struct Envelope {
    var attack = 0.01
    var decay = 0.1
    var sustain = 0.7
    var release = 0.3
    var triggered = true
}

// Global constants
let pi2 = 6.28318530
let sample_rate = 48000
let max_voices = 32
let use_reverb = false
let normalize = true

// State variables
state phase_buffer = [0.0; 32]
state write_pos = 0
state delay_buffer = [0.0; 2048]
state is_playing = false

input mao = false

func sine(freq: Float, phase: Float) -> Float {
    return std.float.sin(pi2 * freq * phase)
}

func clamp(x: Float, lo: Float, hi: Float) -> Float {
    if x < lo {
        return lo
    } else {
        if x > hi {
            return hi
        }
    }
    return x
}

func is_active(osc: Oscillator) -> Bool {
    return osc.active
}

func main() {
    var out = 0.0
    var i = 0
    var gate = false

    loop max_voices {
        if gate {
            let freq = 440.0 * std.float.pow(2.0, (i - 69) / 12.0)
            let sig = sine(freq, 0.0)
            out = out + sig * 0.3
        }
        gate = true
        i = i + 1
    }

    let final_out = clamp(out, -1.0, 1.0)
    var result = [final_out; 2]
    result[0] = final_out
    result[1] = final_out
}
